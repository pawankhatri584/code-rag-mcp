{
  "name": "code-rag-mcp",
  "version": "0.2.0",
  "description": "Lightweight repo-local hybrid (semantic + keyword) code search over MCP. Pure npm — no Docker, no Ollama, no servers. 11 languages via tree-sitter, jina-code embeddings, LanceDB, live file watcher. One command to install.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "code-rag": "src/cli.js"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/cli.js serve",
    "serve": "node src/cli.js serve",
    "index": "node src/cli.js reindex",
    "stats": "node src/cli.js stats"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "claude-code-plugin",
    "rag",
    "code-search",
    "semantic-search",
    "hybrid-search",
    "bm25",
    "rrf",
    "embeddings",
    "tree-sitter",
    "lancedb",
    "jina",
    "lightweight",
    "zero-config"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pawankhatri584/code-rag-mcp.git"
  },
  "homepage": "https://github.com/pawankhatri584/code-rag-mcp#readme",
  "bugs": {
    "url": "https://github.com/pawankhatri584/code-rag-mcp/issues"
  },
  "author": "Pawan Khatri",
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@lancedb/lancedb": "^0.10.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "apache-arrow": "^21.1.0",
    "chokidar": "^4.0.3",
    "ignore": "^5.3.2",
    "tree-sitter": "^0.22.4",
    "tree-sitter-c": "^0.23.6",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-php": "^0.23.12",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.23.3",
    "tree-sitter-typescript": "^0.23.2"
  }
}
